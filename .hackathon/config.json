    "decision_log": "leader-decisions/decision-log.jsonl",
    "notifications": "leader-notifications"
  },
  "research": {
    "web_policy": "always",
    "persona_dataset": "nvidia/Nemotron-Personas-Korea",
    "fallback_persona_dataset": "NLPBada/korean-persona-chat-dataset"
  },
  "product_psychology": {
    "source": "CuriousPaul/product-psychology-for-vibe-coding",
    "checks": [
      "6P storyboard",
      "BMAP",
      "BIAS",
      "Peak-End",
      "Ethics"
    ]
  },
  "verification": {
    "commands": [
      "python3 -m compileall -q harness"
    ]
  },
  "git": {
    "shared_branch": true,
    "push_remote": "origin",
    "push_branch": "HEAD",
    "allow_common_file_edits": false,
    "forbidden_commands": [
      "reset --hard",
      "checkout --",
      "clean -fd",
      "push --force"
    ]
  }
}
